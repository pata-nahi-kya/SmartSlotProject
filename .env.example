# SmartSlot Project Environment Configuration

# ==============================================================================
# FRONTEND CONFIGURATION (smartslot-ui)
# ==============================================================================
# The base URL of the backend API. Vite will only expose variables starting with VITE_ to the client app.
VITE_API_URL=http://localhost:5113/api

# ==============================================================================
# BACKEND CONFIGURATION (SmartSlot.API)
# ==============================================================================
# Environment setting for ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development

# Database Connection String
ConnectionStrings__DefaultConnection=Server=localhost\SQLEXPRESS;Database=SmartSlotDb;Trusted_Connection=True;TrustServerCertificate=True;

# JWT Authentication Settings
# The secret key must be at least 32 characters long
Jwt__Key=longsecretkey123456789987465213itmustbesecret
Jwt__Issuer=SmartSlotAPI
Jwt__Audience=SmartSlotClient
Jwt__ExpireDays=7

# CORS Allowed Origins
Cors__AllowedOrigins__0=http://localhost:5173
Cors__AllowedOrigins__1=http://127.0.0.1:5173

# Security Settings
Security__AllowAdminSelfRegistration=true
Security__RequireHttps=false
Security__MaxLoginAttemptsPerMinute=20
